# Zentrae IT — variables de entorno
# Copia este archivo a `.env.local` y rellena las que necesites.
# Ninguna es obligatoria: el sitio compila y funciona sin ellas (los
# endpoints loguean a stdout y responden 200).

# ─────────────────────────────────────────────
# Lead destinations (formulario + chat)
# Reciben el JSON crudo por POST. Cualquiera de los dos puede ser un
# webhook de n8n, Slack, HubSpot, Make, Zapier, etc.
# ─────────────────────────────────────────────
# CONTACT_WEBHOOK_URL=https://n8n.zentrae.com/webhook/contact
# CHAT_WEBHOOK_URL=https://n8n.zentrae.com/webhook/chat

# ─────────────────────────────────────────────
# Chat agent real (cuando reemplacemos el árbol simulado por Claude)
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# ─────────────────────────────────────────────
# Headless WordPress (cuando migremos contenidos a WP)
# ─────────────────────────────────────────────
# WP_BASE=https://cms.zentrae.com
# WP_AUTH_TOKEN=
